{
  "manifest_version": 3,
  "name": "Bookmark Organizer Pro",
  "description": "Save the active tab to Bookmark Organizer Pro through the local API.",
  "version": "6.4.2",
  "action": {
    "default_title": "Save to Bookmark Organizer Pro",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
